---
title: Alpha EDU — Site Pipeline (P1 Assignment + DD Reporter V4)
---
flowchart TD
    %% ──────────────────────────────────────────────
    %% PHASE 1 — Site Creation
    %% ──────────────────────────────────────────────
    LOI["LOI email arrives<br/><i>process_loi_email MCP</i>"]
    WRIKE["Wrike Site Record created<br/><i>state, city, school_type</i>"]
    P1["P1 Assignment Engine"]

    LOI --> WRIKE --> P1

    %% ──────────────────────────────────────────────
    %% PHASE 2 — P1 Accountable Assignment
    %% ──────────────────────────────────────────────
    P1 --> TYPE_CHECK{school_type?}

    TYPE_CHECK -->|"Growth / Flagship<br/>(250 or 1000)"| AUTO_ASSIGN["Auto-assign both<br/>Thomas Barrow + Israe Zizaoui"]
    TYPE_CHECK -->|"JC Fisher"| EXCLUDED["Excluded — return empty"]
    TYPE_CHECK -->|"Microschool / Unknown"| FETCH_WRIKE["Fetch all Wrike site records<br/><i>build state_contacts + contact_total_sites</i>"]

    FETCH_WRIKE --> HAS_CONTACTS{eligible contacts<br/>found?}
    HAS_CONTACTS -->|No| NO_CONTACTS["Return empty (None)"]
    HAS_CONTACTS -->|Yes| CITY_CHECK{city provided +<br/>SerpAPI key set?}

    CITY_CHECK -->|Yes| RULE1["<b>Rule 1 — Flight scoring</b><br/>Nonstop +100 · Required airline +25/−200<br/>Preferred +25 · Shortest bonus (Devin only)"]
    CITY_CHECK -->|No| RULE2

    RULE1 --> R1_RESULT{winner found?}
    R1_RESULT -->|Yes| ASSIGN_R1["Assign winner (Rule 1)<br/><i>→ Google Chat reasoning</i>"]
    R1_RESULT -->|No| RULE2

    RULE2{contact in<br/>target state?}
    RULE2 -->|"Yes"| ASSIGN_R2["<b>Rule 2 — Same state</b><br/>Fewest total sites wins"]
    RULE2 -->|"No"| RULE3["<b>Rule 3 — Nearest state</b><br/>Haversine distance → fewest sites"]

    RULE3 --> R3_RESULT{found?}
    R3_RESULT -->|Yes| ASSIGN_R3["Assign winner (Rule 3)"]
    R3_RESULT -->|No| NO_CONTACTS2["Return empty (None)"]

    %% ──────────────────────────────────────────────
    %% PHASE 3 — DD Reporter V4 Triggers
    %% ──────────────────────────────────────────────
    INBOX["<b>Inbox Scan</b><br/>Every 15 min, 6a–8p Central<br/><i>scan_inbox.py</i>"]
    SWEEP["<b>Daily Sweep</b><br/>9 AM Central safety net<br/><i>daily_dd_check.py</i>"]
    INTERACTIVE["<b>Interactive</b><br/>Human request via MCP Hive"]

    %% ──────────────────────────────────────────────
    %% Inbox Scan Detail
    %% ──────────────────────────────────────────────
    INBOX --> VENDOR_EMAIL["Vendor email with PDF<br/><i>edu.ops@trilogy.com</i>"]
    VENDOR_EMAIL --> CLASSIFY["GPT-5.2 classification<br/><i>doc_type + matched_site_id + confidence</i>"]
    CLASSIFY --> CONF_CHECK{confidence ≥ 0.7?}
    CONF_CHECK -->|Yes| UPLOAD["Upload to shared Drive folder<br/><i>Standardized filename, dedup check</i>"]
    CONF_CHECK -->|No| FLAG["Flag for manual review<br/><i>→ Google Chat alert</i>"]
    UPLOAD --> MARK["Mark email DD-Processed"]
    MARK --> TRIGGER_PIPELINE["Trigger pipeline for affected sites"]

    %% ──────────────────────────────────────────────
    %% Shared folders
    %% ──────────────────────────────────────────────
    UPLOAD --> SIR_FOLDER[("SIR Folder")]
    UPLOAD --> ISP_FOLDER[("ISP Folder")]
    UPLOAD --> BI_FOLDER[("Inspection Folder")]

    %% ──────────────────────────────────────────────
    %% Document Detection — Three-Tier Classification
    %% ──────────────────────────────────────────────
    TRIGGER_PIPELINE --> READINESS
    SWEEP --> READINESS
    INTERACTIVE --> READINESS

    READINESS["<b>Document detection</b><br/>Search shared folders (substring + LLM fallback)<br/>Fallback: site folder recursive search"]
    READINESS --> TIER1["Tier 1: Regex keywords<br/><i>Free, instant</i>"]
    TIER1 -->|unknown| TIER2["Tier 2: LLM on filename<br/><i>GPT-4o-mini, ~$0.001</i>"]
    TIER2 -->|unknown| TIER3["Tier 3: LLM on PDF content<br/><i>GPT-4o-mini, ~$0.002</i>"]
    TIER1 -->|classified| GATE
    TIER2 -->|classified| GATE
    TIER3 --> GATE

    %% ──────────────────────────────────────────────
    %% Readiness Gate
    %% ──────────────────────────────────────────────
    GATE{"SIR + ISP + Inspection<br/>found AND no report?"}
    GATE -->|"Missing docs"| MISSING_ALERT["Google Chat alert<br/><i>Missing doc checklist</i>"]
    GATE -->|"Report exists"| SKIP["Skip site"]
    GATE -->|"Ready"| AGENT_START

    %% ──────────────────────────────────────────────
    %% PHASE 4 — Agent Pipeline (13 tools, 40 iter)
    %% ──────────────────────────────────────────────
    AGENT_START["<b>Claude Agent Loop</b><br/><i>13 tools, up to 40 iterations</i>"]

    AGENT_START --> STEP2["<b>Step 2</b> — get_site_record<br/><i>Wrike lookup + GPT-5.2 fuzzy match</i>"]
    STEP2 --> STEP3["<b>Step 3</b> — check_site_readiness<br/><i>Confirm doc availability</i>"]
    STEP3 --> STEP3_5["<b>Step 3.5</b> — get_site_comments<br/><i>Wrike comments override API data</i>"]
    STEP3_5 --> STEP4["<b>Step 4</b> — read_drive_document ×3<br/><i>SIR + ISP + Inspection → evidence dict</i>"]

    STEP4 --> STEP5_EOCC["<b>E-Occupancy Skill</b><br/>Score 0–100, zone, tier<br/><i>Auto-publish assessment to Drive</i>"]
    STEP4 --> STEP5_SA["<b>School Approval Skill</b><br/>Approval type, timeline, steps<br/><i>Auto-publish assessment to Drive</i>"]
    STEP4 --> STEP5_COST["<b>Cost Estimate</b><br/>Building Optimizer API<br/><i>MVP + Ideal tiers</i>"]

    STEP5_EOCC --> STEP6
    STEP5_SA --> STEP6
    STEP5_COST --> STEP6

    %% ──────────────────────────────────────────────
    %% V2 Report Compilation
    %% ──────────────────────────────────────────────
    STEP6["<b>Step 6</b> — create_dd_report<br/><i>V2 executive one-pager (28 tokens)</i>"]

    STEP6 --> NORMALIZE["normalize_report_data<br/><i>Flatten → alias map (26) → filter to 28 tokens</i>"]
    NORMALIZE --> DELTAS["compute_deltas (server-side)<br/><i>delta_capacity · delta_cost · delta_ready</i>"]
    DELTAS --> FILL["batchUpdate → Docs API<br/><i>Link tokens as clickable hyperlinks</i>"]
    FILL --> TRACE["Generate trace report<br/><i>Token → source → raw evidence</i>"]

    %% ──────────────────────────────────────────────
    %% V2 Report Sections (subgraph)
    %% ──────────────────────────────────────────────
    subgraph V2_REPORT ["V2 Report — 28 Tokens"]
        direction LR
        META["<b>meta</b> (7)<br/>Name, address, type<br/>date, prepared by, folder"]
        EXEC["<b>exec</b> (15)<br/>Can-we-do-this card (4 dims)<br/>MVP vs Ideal grid (6 + 3 deltas)<br/>Conditions · Risk notes"]
        SOURCES["<b>sources</b> (6)<br/>SIR · Inspection · ISP<br/>E-Occ · School Approval<br/>Trace report"]
    end

    FILL --> V2_REPORT

    %% ──────────────────────────────────────────────
    %% Completeness + Delivery
    %% ──────────────────────────────────────────────
    TRACE --> STEP7["<b>Step 7</b> — check_report_completeness<br/><i>Scan for unfilled tokens</i>"]

    STEP7 --> COMPLETE_CHECK{"{{tokens}}<br/>remaining?"}
    COMPLETE_CHECK -->|"No hard blocks"| STEP8["<b>Step 8</b> — send_dd_report_email<br/><i>Recipients + P1 Accountable owner</i>"]
    COMPLETE_CHECK -->|"Hard blocks found"| INCOMPLETE_ALERT["Google Chat alert<br/><i>Unfilled token list</i>"]

    STEP8 --> MATTERBOT["generate_marketing_pack<br/><i>MatterBot rendering (fire-and-forget)</i>"]
    STEP8 --> DONE(("Report delivered"))

    %% ──────────────────────────────────────────────
    %% Styles
    %% ──────────────────────────────────────────────
    classDef trigger fill:#FAEEDA,stroke:#854F0B,color:#412402
    classDef wrike fill:#EEEDFE,stroke:#534AB7,color:#26215C
    classDef assignment fill:#E1F5EE,stroke:#0F6E56,color:#04342C
    classDef coral fill:#FAECE7,stroke:#993C1D,color:#4A1B0C
    classDef agent fill:#E6F1FB,stroke:#185FA5,color:#042C53
    classDef success fill:#EAF3DE,stroke:#3B6D11,color:#173404
    classDef danger fill:#FCEBEB,stroke:#A32D2D,color:#501313
    classDef neutral fill:#F1EFE8,stroke:#5F5E5A,color:#2C2C2A
    classDef pink fill:#FBEAF0,stroke:#993556,color:#4B1528

    class LOI,INBOX,SWEEP,INTERACTIVE,VENDOR_EMAIL,CLASSIFY,UPLOAD,MARK,TRIGGER_PIPELINE trigger
    class WRIKE,READINESS,GATE,NORMALIZE,DELTAS,FILL,TRACE,STEP6 wrike
    class P1,FETCH_WRIKE,RULE1,ASSIGN_R1,ASSIGN_R2,ASSIGN_R3 assignment
    class AUTO_ASSIGN,STEP8,DONE,STEP5_EOCC,STEP5_SA,STEP5_COST success
    class EXCLUDED,NO_CONTACTS,NO_CONTACTS2,FLAG,MISSING_ALERT,INCOMPLETE_ALERT danger
    class TYPE_CHECK,HAS_CONTACTS,CITY_CHECK,R1_RESULT,R3_RESULT,CONF_CHECK,COMPLETE_CHECK,RULE2 neutral
    class AGENT_START,STEP2,STEP3,STEP3_5,STEP4,STEP7 agent
    class TIER1,TIER2,TIER3 assignment
    class META,EXEC,SOURCES,V2_REPORT wrike
    class MATTERBOT pink
    class SIR_FOLDER,ISP_FOLDER,BI_FOLDER wrike
    class SKIP neutral